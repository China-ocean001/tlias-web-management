<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheima.mapper.OperateLogMapper">

    <select id="list" resultType="com.itheima.pojo.OperateLog">
        select * from operate_log
        <where>
            <if test="begin != null">and operate_time &gt;= #{begin}</if>
            <if test="end != null">and operate_time &lt;= #{end}</if>
        </where>
        order by operate_time desc
    </select>

</mapper>
